    "preview": "NODE_OPTIONS=\"--experimental-global-webcrypto\" vite build && NODE_OPTIONS=\"--experimental-global-webcrypto\" vite preview",
    "backend": "node server/index.js"
  },
  "dependencies": {
    "@opendocsg/pdf2md": "^0.2.7",
    "@xyflow/react": "^12.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-3d": "^1.29.1",
    "three": "^0.184.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^5.0.0"
  }
}
