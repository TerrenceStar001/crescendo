# AI API (NVIDIA NIM / OpenAI compatible) — optional, frontend Settings > AI takes priority
# AI_API_KEY=your-api-key-here
# AI_ENDPOINT=https://integrate.api.nvidia.com/v1
# AI_MODEL=meta/llama-3.1-8b-instruct

# NVIDIA AI (primary provider for AI passage/question generation)
# NVIDIA_API_KEY=nvapi-xxxxx

# Agnes AI (fallback provider)
# AGNES_API_KEY=agnes-xxxxx

# Turso/libSQL remote DB (optional — local SQLite file used by default)
# TURSO_DB_URL=libsql://your-db.turso.io
# TURSO_DB_TOKEN=your-turso-token

# Server
PORT=3001
NODE_ENV=development

# Set to "true" to skip auto-crawl on startup (recommended for production)
# DISABLE_AUTO_CRAWL=true
